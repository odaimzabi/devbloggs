{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "project": ["web/tsconfig.json"]
  },
  "overrides": [
    {
      "files": [
        "**/__tests__/**/*.[jt]s?(x)",
        "**/?(*.)+(spec|test).[jt]s?(x)"
      ],
      "extends": ["plugin:testing-library/react"]
    }
  ],
  "plugins": ["@typescript-eslint", "testing-library"],
  "extends": ["next/core-web-vitals", "plugin:@typescript-eslint/recommended"]
}
